---
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

// Import project images
import img1 from '../assets/photos-films/Au_fond_du_trou.jpg';
import img2 from '../assets/photos-films/Ici_tout_commence.jpeg';
import img3 from '../assets/photos-films/Les_ames_en_peine.jpg';
import img4 from '../assets/photos-films/Un_entretien_saison2.jpeg';
import img5 from '../assets/photos-films/Velensole_1965.jpg';
import img6 from '../assets/photos-films/beautiful_loser.jpg';
import img7 from '../assets/photos-films/des_gens_bien.png';
import img8 from '../assets/photos-films/sentier_paradis.jpeg';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = [
	{
		title: "Au fond du trou",
		category: "Fiction",
		image: img1,
		year: "2023"
	},
	{
		title: "Ici tout commence",
		category: "Série TV",
		image: img2,
		year: "2022"
	},
	{
		title: "Les âmes en peine",
		category: "Documentaire",
		image: img3,
		year: "2023"
	},
	{
		title: "Un entretien - Saison 2",
		category: "Série TV / Comédie",
		image: img4,
		year: "2022"
	},
	{
		title: "Velensole 1965",
		category: "Court Métrage",
		image: img5,
		year: "2021"
	},
	{
		title: "Beautiful Loser",
		category: "Fiction",
		image: img6,
		year: "2022"
	},
	{
		title: "Des gens bien",
		category: "Série TV",
		image: img7,
		year: "2023"
	},
	{
		title: "Sentier Paradis",
		category: "Documentaire",
		image: img8,
		year: "2022"
	}
];
---

<section id="portfolio" class="py-24 bg-[#050505]">
	<div class="container mx-auto px-6 md:px-12">
		<div class="flex flex-col md:flex-row justify-between items-end mb-16">
			<div class="max-w-2xl">
				<h2 class="text-xs font-bold tracking-[0.3em] text-[#D4AF37] uppercase mb-4">{t('portfolio.title')}</h2>
				<h3 class="text-4xl md:text-6xl font-black text-white uppercase font-display leading-none">
					{t('portfolio.subtitle_1')} <br/> <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-600">{t('portfolio.subtitle_2')}</span>
				</h3>
			</div>
			<div class="mt-8 md:mt-0">
				<a href="https://www.imdb.com/name/nm4502347/" target="_blank" class="text-sm uppercase tracking-widest text-[#D4AF37] hover:text-white transition-colors duration-300 flex items-center gap-2">
					{t('portfolio.imdb_link')} 
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-up-right"><path d="M7 7h10v10"></path><path d="M7 17 17 7"></path></svg>
				</a>
			</div>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-1">
			{projects.map((project, index) => (
				<div class="group relative aspect-[3/4] overflow-hidden bg-[#111]">
					<Image 
						src={project.image} 
						alt={project.title} 
						class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700 ease-in-out opacity-60 group-hover:opacity-100"
						loading="lazy"
						width={600}
						height={800}
					/>
					<div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
					<div class="absolute inset-0 p-8 flex flex-col justify-end transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
						<p class="text-[#D4AF37] text-[10px] font-bold tracking-[0.2em] uppercase mb-1">
							{project.category.replace('Série TV', lang === 'fr' ? 'Série TV' : 'TV Series').replace('Documentaire', lang === 'fr' ? 'Documentaire' : 'Documentary').replace('Court Métrage', lang === 'fr' ? 'Court Métrage' : 'Short Film')} · {project.year}
						</p>
						<h4 class="text-white text-xl font-bold uppercase font-display leading-tight">{project.title}</h4>
					</div>
					<!-- Hover Border -->
					<div class="absolute inset-0 border border-white/0 group-hover:border-white/10 transition-all duration-500 pointer-events-none"></div>
				</div>
			))}
		</div>
	</div>
</section>
