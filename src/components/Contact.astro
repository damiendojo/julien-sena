---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contact" class="py-24 bg-[#0A0A0A] border-t border-white/5 relative overflow-hidden">
	<div class="absolute -bottom-40 -right-40 w-96 h-96 bg-[#D4AF37]/5 rounded-full blur-[120px]"></div>
	
	<div class="container mx-auto px-6 md:px-12 relative z-10">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
			<div>
				<h2 class="text-xs font-bold tracking-[0.3em] text-[#D4AF37] uppercase mb-4">{t('contact.title')}</h2>
				<h3 class="text-4xl md:text-6xl font-black text-white uppercase font-display leading-[0.9] mb-8">
					{t('contact.subtitle_1')} <br/> <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-500">{t('contact.subtitle_2')}</span>
				</h3>
				<p class="text-gray-400 text-lg mb-12 max-w-md">
					{t('contact.description')}
				</p>
				
				<div class="space-y-8">
					<div class="flex items-center gap-6 group">
						<div class="w-12 h-12 bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-[#D4AF37] group-hover:border-[#D4AF37] transition-all duration-500">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
						</div>
						<div>
							<p class="text-[10px] uppercase tracking-widest text-[#D4AF37] font-bold">Email</p>
							<a href="mailto:julien.sena@gmail.com" class="text-xl text-white font-bold hover:text-[#D4AF37] transition-colors">julien.sena@gmail.com</a>
						</div>
					</div>

					<div class="flex items-center gap-6 group">
						<div class="w-12 h-12 bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-[#D4AF37] group-hover:border-[#D4AF37] transition-all duration-500">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
						</div>
						<div>
							<p class="text-[10px] uppercase tracking-widest text-[#D4AF37] font-bold">Localisation</p>
							<p class="text-xl text-white font-bold">Romainville, France</p>
						</div>
					</div>
				</div>

				<div class="mt-16 flex gap-6">
					<a href="https://www.imdb.com/name/nm4502347/" target="_blank" class="text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-white transition-colors">IMDB</a>
					<a href="https://www.unifrance.org/annuaires/personne/373018/julien-sena" target="_blank" class="text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-white transition-colors">Unifrance</a>
				</div>
			</div>

			<form class="space-y-6 bg-white/5 p-8 border border-white/10 backdrop-blur-sm">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					<div class="space-y-2">
						<label class="text-[10px] uppercase tracking-widest text-gray-500 font-bold ml-1">{t('contact.form.name_label')}</label>
						<input type="text" placeholder={t('contact.form.name_placeholder')} class="w-full bg-[#050505] border border-white/10 px-4 py-4 text-white text-sm focus:border-[#D4AF37] outline-none transition-colors" />
					</div>
					<div class="space-y-2">
						<label class="text-[10px] uppercase tracking-widest text-gray-500 font-bold ml-1">{t('contact.form.email_label')}</label>
						<input type="email" placeholder={t('contact.form.email_placeholder')} class="w-full bg-[#050505] border border-white/10 px-4 py-4 text-white text-sm focus:border-[#D4AF37] outline-none transition-colors" />
					</div>
				</div>
				<div class="space-y-2">
					<label class="text-[10px] uppercase tracking-widest text-gray-500 font-bold ml-1">{t('contact.form.subject_label')}</label>
					<input type="text" placeholder={t('contact.form.subject_placeholder')} class="w-full bg-[#050505] border border-white/10 px-4 py-4 text-white text-sm focus:border-[#D4AF37] outline-none transition-colors" />
				</div>
				<div class="space-y-2">
					<label class="text-[10px] uppercase tracking-widest text-gray-500 font-bold ml-1">{t('contact.form.message_label')}</label>
					<textarea rows="4" placeholder={t('contact.form.message_placeholder')} class="w-full bg-[#050505] border border-white/10 px-4 py-4 text-white text-sm focus:border-[#D4AF37] outline-none transition-colors resize-none"></textarea>
				</div>
				<button type="submit" class="w-full py-4 bg-[#D4AF37] hover:bg-white text-black font-black uppercase tracking-[0.2em] text-xs transition-all duration-500">
					{t('contact.form.send')}
				</button>
			</form>
		</div>
	</div>
</section>
