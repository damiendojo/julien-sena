---
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

// Import images for Astro optimization
import hero1 from '../assets/photos/hero_1.jpg';
import hero2 from '../assets/photos/IMG_1792.JPG';
import hero3 from '../assets/photos/IMG_20250918_092233.jpg';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative h-screen w-full overflow-hidden flex items-center">
	<!-- Background Slider -->
	<div class="absolute inset-0 z-0 overflow-hidden">
		<div id="hero-slider" class="relative w-full h-full">
			<div class="hero-slide absolute inset-0 opacity-100 transition-opacity duration-1000 ease-in-out">
				<Image 
					src={hero1} 
					alt="Julien Sena Tournage 1" 
					class="w-full h-full object-cover scale-110 animate-ken-burns"
					loading="eager"
					fetchpriority="high"
				/>
			</div>
			<div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-1000 ease-in-out">
				<Image 
					src={hero2} 
					alt="Julien Sena Tournage 2" 
					class="w-full h-full object-cover scale-110"
					loading="lazy"
				/>
			</div>
			<div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-1000 ease-in-out">
				<Image 
					src={hero3} 
					alt="Julien Sena Tournage 3" 
					class="w-full h-full object-cover scale-110"
					loading="lazy"
				/>
			</div>
		</div>
		<!-- Overlays -->
		<div class="absolute inset-0 bg-[#050505]/60 z-10 backdrop-blur-[2px]"></div>
		<div class="absolute inset-0 bg-gradient-to-b from-[#050505]/40 via-transparent to-[#050505] z-10"></div>
	</div>

	<div class="container mx-auto px-6 md:px-12 relative z-10 pt-20">
		<div class="max-w-4xl">
			<div class="overflow-hidden mb-4">
				<p id="hero-subtitle" class="text-[#D4AF37] font-bold tracking-[0.3em] uppercase text-xs md:text-sm animate-reveal-up">
					{t('hero.subtitle')}
				</p>
			</div>
			
			<h1 id="hero-title" class="text-5xl md:text-8xl font-black text-white leading-tight mb-8 tracking-tighter uppercase font-display animate-reveal-up delay-200">
				{t('hero.title').split('.')[0]}<br/> <span class="text-transparent border-b-2 border-white/20 pb-2 bg-clip-text bg-gradient-to-r from-white to-gray-500">{t('hero.title').split('.')[1] || ''}</span>
			</h1>

			<p id="hero-description" class="text-lg md:text-xl text-gray-400 max-w-2xl leading-relaxed mb-10 animate-reveal-up delay-400">
				{t('hero.description')}
			</p>

			<div class="flex flex-col sm:flex-row gap-4 animate-reveal-up delay-600">
				<a href="#portfolio" class="px-10 py-4 bg-[#D4AF37] text-black font-bold uppercase tracking-widest text-xs rounded-none hover:bg-white transiton-colors duration-500 text-center">
					{t('hero.cta.portfolio')}
				</a>
				<a href="#contact" class="px-10 py-4 border border-white/20 text-white font-bold uppercase tracking-widest text-xs rounded-none hover:bg-white hover:text-black transition-all duration-500 text-center">
					{t('hero.cta.contact')}
				</a>
			</div>
		</div>
	</div>

	<!-- Scroll Indicator -->
	<div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center space-y-4">
		<span class="text-[10px] uppercase tracking-[0.5em] text-gray-500 font-bold">Scroll</span>
		<div class="w-[1px] h-16 bg-gradient-to-b from-[#D4AF37] to-transparent animate-bounce"></div>
	</div>
</section>

<style>
	@keyframes revealUp {
		from {
			opacity: 0;
			transform: translateY(100%);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes kenburns {
		0% { transform: scale(1.1) translate(0, 0); }
		50% { transform: scale(1.2) translate(-1%, 1%); }
		100% { transform: scale(1.1) translate(0, 0); }
	}

	.animate-ken-burns {
		animation: kenburns 20s linear infinite;
	}

	.hero-slide.active {
		opacity: 1;
		z-index: 1;
	}

	.hero-slide {
		z-index: 0;
	}

	.animate-reveal-up {
		opacity: 0;
		animation: revealUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	.delay-200 { animation-delay: 0.2s; }
	.delay-400 { animation-delay: 0.4s; }
	.delay-600 { animation-delay: 0.6s; }
</style>

<script>
	// Slider Logic
	const slides = document.querySelectorAll('.hero-slide');
	let currentSlide = 0;

	function nextSlide() {
		const current = slides[currentSlide] as HTMLElement;
		current.classList.remove('opacity-100');
		current.classList.add('opacity-0');
		current.querySelector('img')?.classList.remove('animate-ken-burns');
		
		currentSlide = (currentSlide + 1) % slides.length;
		
		const next = slides[currentSlide] as HTMLElement;
		next.classList.remove('opacity-0');
		next.classList.add('opacity-100');
		next.querySelector('img')?.classList.add('animate-ken-burns');
	}

	if (slides.length > 0) {
		setInterval(nextSlide, 6000);
	}

	// Parallax effect
	const slider = document.getElementById('hero-slider');
	window.addEventListener('scroll', () => {
		const scroll = window.scrollY;
		if (slider) {
			slider.style.transform = `translateY(${scroll * 0.3}px)`;
		}
	});
</script>
