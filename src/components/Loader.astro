---
---

<div id="loader" class="fixed inset-0 z-[100] bg-[#050505] flex items-center justify-center transition-opacity duration-1000">
	<div class="flex flex-col items-center">
		<!-- Animated Equalizer Logo -->
		<div class="flex items-end space-x-1 h-12 mb-4">
			<div class="w-1 bg-[#D4AF37] animate-eq-1 h-3"></div>
			<div class="w-1 bg-[#D4AF37] animate-eq-2 h-6"></div>
			<div class="w-1 bg-[#D4AF37] animate-eq-3 h-10"></div>
			<div class="w-1 bg-[#D4AF37] animate-eq-4 h-5"></div>
			<div class="w-1 bg-[#D4AF37] animate-eq-5 h-8"></div>
			<div class="w-1 bg-white animate-eq-6 h-4"></div>
			<div class="w-1 bg-white animate-eq-1 h-7"></div>
		</div>
		<div class="overflow-hidden">
			<span class="text-white text-xl font-bold tracking-[0.3em] uppercase font-display animate-reveal-up-loader">
				Julien Sena
			</span>
		</div>
	</div>
</div>

<style>
	@keyframes eq {
		0%, 100% { height: 20%; }
		50% { height: 100%; }
	}

	.animate-eq-1 { animation: eq 0.6s infinite ease-in-out; }
	.animate-eq-2 { animation: eq 0.8s infinite ease-in-out; }
	.animate-eq-3 { animation: eq 0.5s infinite ease-in-out; }
	.animate-eq-4 { animation: eq 0.9s infinite ease-in-out; }
	.animate-eq-5 { animation: eq 0.7s infinite ease-in-out; }
	.animate-eq-6 { animation: eq 0.4s infinite ease-in-out; }

	@keyframes revealUpLoader {
		from { transform: translateY(100%); opacity: 0; }
		to { transform: translateY(0); opacity: 1; }
	}

	.animate-reveal-up-loader {
		animation: revealUpLoader 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	#loader.fade-out {
		opacity: 0;
		pointer-events: none;
	}
</style>

<script>
	window.addEventListener('load', () => {
		const loader = document.getElementById('loader');
		setTimeout(() => {
			if (loader) {
				loader.classList.add('fade-out');
			}
		}, 1500); // Show loader for at least 1.5s for the feel
	});
</script>
