---
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

import profileImg from '../assets/photos/JulienSena.jpeg';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const clients = ["L'oréal", "Mac donald's", "SNCF", "Universal Music", "Renault", "Citröen", "Möet Hennessy", "Enedis"];
---

<section id="about" class="py-24 bg-[#050505] overflow-hidden">
	<div class="container mx-auto px-6 md:px-12">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
			<div class="relative">
				<div class="absolute -top-20 -left-20 w-64 h-64 bg-[#D4AF37]/10 rounded-full blur-[100px]"></div>
				<Image 
					src={profileImg} 
					alt="Julien Sena" 
					class="relative z-10 w-full aspect-[4/5] object-cover border border-white/10"
					loading="lazy"
				/>
				<div class="absolute -bottom-6 -right-6 w-32 h-32 border-b border-r border-[#D4AF37] z-20"></div>
			</div>
			
			<div class="flex flex-col justify-center">
				<h2 class="text-xs font-bold tracking-[0.3em] text-[#D4AF37] uppercase mb-4">{t('about.title')}</h2>
				<h3 class="text-4xl md:text-6xl font-black text-white uppercase font-display leading-tight mb-8">
					{lang === 'fr' ? 'Une approche' : 'A'} <span class="italic text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-500">{lang === 'fr' ? 'Passionnée' : 'Passionate'}</span> {lang === 'fr' ? 'du Son' : 'approach to Sound'}
				</h3>
				
				<div class="space-y-6 text-gray-400 text-lg leading-relaxed">
					<p>
						{t('about.description')}
					</p>
					<p>
						{t('about.clients_prefix')}
					</p>
				</div>

				<div class="mt-8 flex flex-wrap gap-3">
					{clients.map(client => (
						<span class="px-4 py-2 bg-white/5 border border-white/10 text-xs font-bold uppercase tracking-widest text-[#D4AF37]">
							{client}
						</span>
					))}
				</div>

				<div class="mt-12">
					<a href="https://www.imdb.com/name/nm4502347/" target="_blank" class="inline-flex items-center gap-4 group">
						<span class="w-12 h-[1px] bg-white/20 group-hover:w-16 group-hover:bg-[#D4AF37] transition-all duration-500"></span>
						<span class="text-sm font-bold uppercase tracking-widest text-white group-hover:text-[#D4AF37] transition-colors">{t('about.cv_link')}</span>
					</a>
				</div>
			</div>
		</div>
	</div>
</section>
