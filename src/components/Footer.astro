---
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

import logoImg from '../assets/logos/LogoSena.png';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="py-12 bg-[#050505] border-t border-white/5">
    <div class="container mx-auto px-6 md:px-12 flex flex-col md:flex-row justify-between items-center gap-8">
        <div class="flex items-center space-x-3">
            <Image 
                src={logoImg} 
                alt="Julien Sena Logo" 
                class="h-8 w-auto filter invert brightness-200" 
                loading="lazy"
            />
        </div>
        
        <div class="text-gray-500 text-[10px] uppercase tracking-widest font-bold">
            © 2026 Julien Sena. {t('footer.rights')}
        </div>
        
        <div class="flex space-x-6">
            <a href="https://www.imdb.com/name/nm4502347/" target="_blank" class="text-gray-400 hover:text-[#D4AF37] transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-film"><rect width="18" height="18" x="3" y="3" rx="2"></rect><path d="M7 3v18"></path><path d="M17 3v18"></path><path d="M3 7h4"></path><path d="M3 12h4"></path><path d="M3 17h4"></path><path d="M17 7h4"></path><path d="M17 12h4"></path><path d="M17 17h4"></path></svg>
            </a>
            <a href="https://www.unifrance.org/annuaires/personne/373018/julien-sena" target="_blank" class="text-gray-400 hover:text-[#D4AF37] transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
            </a>
            <a href="https://www.instagram.com/julien_sena/" target="_blank" class="text-gray-400 hover:text-[#D4AF37] transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
            </a>
        </div>
    </div>
</footer>
