---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Portfolio from '../components/Portfolio.astro';
import Equipment from '../components/Equipment.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
	title="Julien Sena | Production Sound Mixer" 
	description="Ingénieur du Son / Production Sound Mixer basé en région parisienne. Spécialisé en documentaires et fictions pour le cinéma et la télévision."
	{/* @ts-ignore */}
	lang="fr"
>
	<script is:inline>
		(function() {
			const savedLang = localStorage.getItem('preferred-lang');
			if (savedLang === 'en') {
				window.location.replace('/en/');
				return;
			}
			if (!savedLang) {
				const browserLang = navigator.language || navigator.userLanguage || '';
				if (browserLang.startsWith('en')) {
					window.location.replace('/en/');
				}
			}
		})();
	</script>
	<Navbar />
	<main>
		<Hero />
		<About />
		<Portfolio />
		<Equipment />
		<Contact />
	</main>
	<Footer />
</Layout>
